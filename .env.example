# App
APP_NAME=ai-business-process-automation
APP_ENV=development
APP_PORT=8000
FRONTEND_PORT=5173
API_KEY=dev-api-key
CORS_ORIGINS=http://localhost:5173

# Database
POSTGRES_DB=automation
POSTGRES_USER=automation
POSTGRES_PASSWORD=automation
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://automation:automation@postgres:5432/automation

# Queue
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# AI Provider
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:7b
REQUEST_TIMEOUT_SECONDS=120

# Security
SECRET_KEY=change-me
# Optional: set to a random string to require HMAC-SHA256 signature on webhook triggers
WEBHOOK_SECRET=

# SMTP (optional if SMTP_DRY_RUN=true)
SMTP_DRY_RUN=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@example.local

# Frontend
VITE_API_BASE_URL=http://localhost:8000
VITE_API_KEY=dev-api-key
